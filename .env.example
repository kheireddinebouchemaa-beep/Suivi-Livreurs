# SUPABASE_URL: URL du projet Supabase (ex: https://xxxxx.supabase.co)
SUPABASE_URL="https://xxxxx.supabase.co"

# SUPABASE_SERVICE_KEY: clé service_role Supabase (format JWT legacy "eyJ...", pas le nouveau format "sb_secret_...").
# Récupérable dans Supabase sous l'onglet "Clés API héritage anonyme, service_role".
SUPABASE_SERVICE_KEY="eyJ..."
